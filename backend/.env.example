DATABASE_URL="postgresql://user:password@localhost:5432/database_name?sslmode=disable"
SOLANA_RPC_URL="https://api.devnet.solana.com"
# USDC mint address (defaults to devnet USDC)
USDC_MINT="4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU"
REDIS_URL=redis://localhost:6379/0

# Auth/session
AUTH_JWT_SECRET="change-this-to-a-long-random-secret"
AUTH_COOKIE_NAME="spw_session"
AUTH_COOKIE_SECURE="false" # false on local HTTP, true on HTTPS

# Google OAuth (optional, required for /api/auth/google)
GOOGLE_CLIENT_ID=""

# Agent API access (optional)
# Generate once: AGENT_ACCESS_KEY="your-plain-agent-key"
# Then set AGENT_ACCESS_KEY_SHA256 to sha256(AGENT_ACCESS_KEY) hex string.
# Example: echo -n "your-plain-agent-key" | sha256sum | awk '{print $1}'
AGENT_ACCESS_KEY_SHA256=""
# Owner identity used for event ownership when agent calls authenticated endpoints.
AGENT_ACCESS_EMAIL="agent.integration@yourdomain.com"
