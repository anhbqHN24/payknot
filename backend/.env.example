DATABASE_URL="postgresql://user:password@localhost:5432/database_name?sslmode=disable"
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
# USDC mint address (mainnet USDC)
USDC_MINT="EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v"
REDIS_URL=redis://localhost:6379/0

# Auth/session
AUTH_JWT_SECRET="change-this-to-a-long-random-secret"
AUTH_COOKIE_NAME="spw_session"
AUTH_COOKIE_SECURE="false" # false on local HTTP, true on HTTPS

# Google OAuth (optional, required for /api/auth/google)
GOOGLE_CLIENT_ID=""

# Email verification
APP_BASE_URL="https://pay.crea8r.xyz"
# log | smtp
EMAIL_VERIFICATION_MODE="log"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Agent API access via asymmetric signatures (optional)
# JSON map: {"agent-id":"base64-ed25519-public-key"}
# Example:
# AGENT_PUBLIC_KEYS_JSON='{"agent-a":"xBase64PublicKey==","agent-b":"yBase64PublicKey=="}'
AGENT_PUBLIC_KEYS_JSON=""

# Agent runtime JWT (nonce -> token flow)
AGENT_JWT_SECRET=""

# Automation settlement mode
# true: return mock tx signature for integration testing
# false: requires real signer integration (not included in this foundation)
SETTLEMENT_MOCK_SUCCESS="true"
