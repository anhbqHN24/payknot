# =============================
# Compose-wide single source env
# Copy to: .env.compose
# docker compose --env-file .env.compose up -d --build
# =============================

# --- Postgres ---
POSTGRES_DB=payknot
POSTGRES_USER=payknot
POSTGRES_PASSWORD=change_me_strong_password

# Used by backend
DATABASE_URL=postgresql://payknot:change_me_strong_password@postgres:5432/payknot?sslmode=disable

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Backend app ---
SOLANA_RPC_URL=https://api.devnet.solana.com
USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
AUTH_JWT_SECRET=change-this-to-a-long-random-secret
AUTH_COOKIE_NAME=spw_session
AUTH_COOKIE_SECURE=false
GOOGLE_CLIENT_ID=

# --- Frontend (NEXT_PUBLIC_ values are baked at build time) ---
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
NEXT_PUBLIC_MERCHANT_WALLET=insert_merchant_wallet_address_here
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Frontend rewrite target for /api/*
# Inside compose network, backend is reachable at http://backend:8080
API_PROXY_TARGET=http://backend:8080
